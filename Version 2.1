# ══════════════════════════════════════════════════════════════════════════════
print("\n── Section 11: Disturbance Rejection  [Book §2.5 p.72] ──────────────")

F_dist, t_onset = 5.0, 1.0

def cl_with_disturbance(t, z_aug):
    z, ei = z_aug[:4], z_aug[4]
    x_n, xd_n, i_n, xm_n = z
    e    = x_sp_n - xm_n
    ed   = -(xm_n - x_n) / tau_n
    u    = float(np.clip(V_e_val + pid_u(e, ei, ed), 0, V_e_val*4))
    dz   = f_nonlinear(t, z, lambda t: u)
    if t >= t_onset:
        dz[1] += F_dist / m_eff_n
    return dz + [e]

t_d   = np.linspace(0, 3.0, 8000)
sol_d = spi.solve_ivp(cl_with_disturbance, [0, 3.0], z0_aug,
                      t_eval=t_d, method='RK45', rtol=1e-8, atol=1e-10)

fig, ax = plt.subplots(figsize=(10, 4))
ax.plot(sol_d.t, (sol_d.y[3] - x_sp_n)*100, lw=1.8)
ax.axhline(0, color='gray', ls=':', lw=1.1, label="Set-point")
ax.axvline(t_onset, color='salmon', ls='--', alpha=0.8,
           label=f"Disturbance Fd = {F_dist} N")
ax.set_xlabel("Time (s)"); ax.set_ylabel("x̄m (cm)")
ax.set_title(
    "Disturbance rejection  [Coursework req. (iv)]\n"
    "FVT (Book Thm 4.29, p.164) → integral action restores zero offset"
)
ax.legend(fontsize=9); ax.grid(True, alpha=0.25)
plt.tight_layout()
plt.savefig("ele2038_disturbance.pdf", bbox_inches="tight")
plt.show()

ss_err = (sol_d.y[3, -1] - x_sp_n) * 100
print(f"  Steady-state error after disturbance: {ss_err:.5f} cm  (→ 0 by FVT)")

